import "asd.fl"

class Reader {
    init(name) {
        this.text = "";
        this.name = name;
    }
    read(filename) {
        this.text = read(filename);
    }
}
var a = 2;
var reader = Reader(a);
reader.read("fasz.txt");
out reader.text;
out reader.name;

var asd = [];
out asd;
asd.add();
out asd.add();

testAsd();

fn testTest() {
    out "testTest ran successfully!";
}

testTest();