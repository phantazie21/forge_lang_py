out "+=";
for (var i = 0; i < 100; i += 1) {
    out i;
}
out "*=";
for (var i = 2; i < 100; i *= 2) {
    out i;
}
out "/=";
for (var i = 100; i > 1; i /= 5) {
    out i;
}
out "-=";
for (var i = 100; i > 0; i -= 10) {
    out i;
}
out "++";
for (var i = 0; i < 10; i++) {
    out i;
}
out "--";
for (var i = 10; i > 0; i--) {
    out i;
}