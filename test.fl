var a = 0;
var temp;

for (var b = 1; a < 10000; b = temp + b) {
    out a;
    temp = a;
    a = b;
    out b + ". iteracio";
    if (a > 100){
        break;
    }
}

while (true){
    a = a / 10;
    if (a < 10) {
        break;
    }
    out a;
}

if (a < 10) {
    out a + " is greater than 10";
}
else {
    out a + " is less than 10";
}